---
// src/components/CartDrawer.astro
---

<div 
  id="cart-drawer" 
  class="fixed inset-y-0 right-0 z-[100] w-full max-w-md bg-white shadow-2xl transform translate-x-full transition-transform duration-500 ease-in-out flex flex-col h-full overflow-hidden"
>
  <div class="p-6 border-b border-neutral-100 flex justify-between items-center bg-white shrink-0">
    <div class="flex items-baseline gap-2">
      <h2 class="text-sm font-bold tracking-[0.2em] uppercase text-neutral-900 font-sans">Mi Bolsa</h2>
      <span id="cart-drawer-count" class="text-xs font-mono text-neutral-400">(0)</span>
    </div>
    <button 
      id="close-cart-btn" 
      class="text-neutral-400 hover:text-neutral-900 transition-colors p-2 -mr-2 cursor-pointer"
      title="Cerrar Carrito"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <div id="cart-empty-state" class="flex-grow flex flex-col items-center justify-center p-6 text-center space-y-4">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-12 h-12 text-neutral-300">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375 .375 0 1 1-.75 0 .375 .375 0 0 1 .75 0Zm7.5 0a.375 .375 0 1 1-.75 0 .375 .375 0 0 1 .75 0Z" />
    </svg>
    <p class="text-xs tracking-wider text-neutral-400 uppercase font-medium">Tu bolsa está vacía</p>
    <button id="back-to-shop-btn" class="text-[10px] font-bold tracking-widest uppercase border border-neutral-200 px-6 py-2.5 hover:border-neutral-900 transition-colors cursor-pointer">
      Seguir Viendo
    </button>
  </div>

  <div 
    id="cart-items-container" 
    class="w-full flex-1 min-h-0 overflow-y-auto p-6 space-y-6 hidden overscroll-contain outline-none"
    tabindex="0"
    data-lenis-prevent
  ></div>

  <div id="cart-footer" class="p-6 border-t border-neutral-100 bg-neutral-50 space-y-4 hidden shrink-0">
    <div class="flex justify-between items-baseline">
      <span class="text-xs font-medium tracking-widest uppercase text-neutral-500">Subtotal Estimado</span>
      <span id="cart-subtotal" class="text-sm font-bold tracking-wider text-neutral-900">0.00 €</span>
    </div>
    <p class="text-[10px] text-neutral-400 leading-normal">
      * Al presionar el botón se generará tu orden de compra consolidada para consultar la disponibilidad directamente con Samuel por WhatsApp.
    </p>
    <a 
      id="checkout-whatsapp-btn"
      href="#" 
      target="_blank" 
      class="w-full block text-center bg-neutral-900 text-white text-xs font-semibold tracking-[0.2em] uppercase py-4 hover:bg-neutral-800 transition-colors shadow-sm"
    >
      Consultar Pedido Completo
    </a>
  </div>
</div>

<div 
  id="cart-overlay" 
  class="fixed inset-0 z-[90] bg-black/40 backdrop-blur-xs hidden opacity-0 transition-opacity duration-500"
></div>

<script>
  import { cartItems, removeCartItem, clearCart } from '../store/cartStore.js';

  interface CartItem {
    id: string;
    sku: string;
    name: string;
    price: number;
    colorName: string;
    colorHex: string;
    size: string;
    image: string;
    quantity: number;
  }

  const cartDrawer = document.getElementById('cart-drawer');
  const cartOverlay = document.getElementById('cart-overlay');
  const closeCartBtn = document.getElementById('close-cart-btn');
  const backToShopBtn = document.getElementById('back-to-shop-btn');
  
  const drawerCount = document.getElementById('cart-drawer-count');
  const emptyState = document.getElementById('cart-empty-state');
  const itemsContainer = document.getElementById('cart-items-container');
  const cartFooter = document.getElementById('cart-footer');
  const cartSubtotal = document.getElementById('cart-subtotal');
  const checkoutWhatsappBtn = document.getElementById('checkout-whatsapp-btn') as HTMLAnchorElement;

  // --- LÓGICA DE APERTURA ---
  const openCart = () => {
    if (!cartDrawer || !cartOverlay || !itemsContainer) return;
    
    cartDrawer.classList.remove('translate-x-full');
    cartOverlay.classList.remove('hidden');
    setTimeout(() => cartOverlay.classList.remove('opacity-0'), 10);
    
    // Bloquear scroll global del Home
    document.body.style.overflow = 'hidden';
    
    // Enfocar la lista internamente
    setTimeout(() => {
      itemsContainer.focus();
    }, 50);
  };

  document.getElementById('open-cart-btn')?.addEventListener('click', openCart);

  // --- LÓGICA PARA CERRAR ---
  const closeCart = () => {
    if (!cartDrawer || !cartOverlay) return;
    cartDrawer.classList.add('translate-x-full');
    cartOverlay.classList.add('opacity-0');
    setTimeout(() => {
      cartOverlay.classList.add('hidden');
      document.body.style.overflow = ''; 
    }, 400);
  };

  closeCartBtn?.addEventListener('click', closeCart);
  backToShopBtn?.addEventListener('click', closeCart);
  cartOverlay?.addEventListener('click', closeCart);

  // --- AISLAMIENTO ACÚSTICO DEL MOUSE WHEEL (EVITA INTERCEPCIÓN DEL HOME) ---
  if (itemsContainer) {
    itemsContainer.addEventListener('wheel', (e) => {
      // Detiene por completo que el evento suba al body o librerías externas de scroll fluido
      e.stopPropagation();
    }, { passive: true });

    itemsContainer.addEventListener('touchmove', (e) => {
      // Hace lo mismo para el deslizamiento táctil en móviles
      e.stopPropagation();
    }, { passive: true });
  }

  // --- RENDERIZADO DINÁMICO DESDE NANOSTORES ---
  cartItems.subscribe((items: CartItem[]) => {
    if (!drawerCount || !emptyState || !itemsContainer || !cartFooter || !cartSubtotal || !checkoutWhatsappBtn) return;

    const totalItems = items.reduce((acc: number, item: CartItem) => acc + item.quantity, 0);
    drawerCount.textContent = `(${totalItems})`;

    if (items.length === 0) {
      emptyState.classList.remove('hidden');
      itemsContainer.classList.add('hidden');
      cartFooter.classList.add('hidden');
      return;
    }

    emptyState.classList.add('hidden');
    itemsContainer.classList.remove('hidden');
    cartFooter.classList.remove('hidden');

    itemsContainer.innerHTML = '';
    let subtotal = 0;

    items.forEach((item: CartItem) => {
      subtotal += item.price * item.quantity;
      
      const itemElement = document.createElement('div');
      itemElement.className = 'flex items-center justify-between border-b border-neutral-100 pb-4 last:border-0 last:pb-0 gap-4 w-full shrink-0';
      itemElement.innerHTML = `
        <div class="flex items-center gap-4 min-w-0 flex-1">
          <div class="w-16 h-20 bg-neutral-50 border border-neutral-100 overflow-hidden flex-shrink-0">
            <img src="${item.image}" alt="${item.name}" class="w-full h-full object-cover object-center" />
          </div>
          <div class="space-y-1 min-w-0 flex-1">
            <h4 class="text-xs font-bold tracking-wider text-neutral-800 uppercase truncate">${item.name}</h4>
            <p class="text-[10px] font-mono tracking-widest text-neutral-400 uppercase truncate">${item.sku}</p>
            <p class="text-[10px] text-neutral-500 truncate">
              Talla: <span class="font-mono font-bold text-neutral-800">${item.size}</span> | 
              Color: <span class="text-neutral-800">${item.colorName}</span>
            </p>
            <p class="text-xs font-bold text-neutral-900 mt-1">${item.price} € <span class="text-[10px] font-normal text-neutral-400">x ${item.quantity}</span></p>
          </div>
        </div>
        <button 
          data-remove-id="${item.id}"
          class="text-neutral-300 hover:text-red-600 transition-colors p-2 flex-shrink-0 cursor-pointer"
          title="Eliminar artículo"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-1.816A2.25 2.25 0 0 0 13.812 3H10.188a2.25 2.25 0 0 0-2.25 2.25V5.79m7.493 0c-1.22-.12-2.47-.18-3.75-.18s-2.53.06-3.75.18" />
          </svg>
        </button>
      `;

      const removeBtn = itemElement.querySelector('[data-remove-id]');
      removeBtn?.addEventListener('click', () => {
        const id = removeBtn.getAttribute('data-remove-id');
        if (id) removeCartItem(id);
      });

      itemsContainer.appendChild(itemElement);
    });

    cartSubtotal.textContent = `${subtotal.toFixed(2)} €`;

    let text = `¡Hola VKMEN! Me interesa consultar la disponibilidad de este pedido:\n\n`;
    items.forEach((item: CartItem, index: number) => {
      text += `${index + 1}. ${item.name}\n`;
      text += `   [SKU: ${item.sku}] | Talla: ${item.size} | Color: ${item.colorName}\n`;
      text += `   Cantidad: ${item.quantity} pza(s) — Precio: ${item.price} € c/u\n\n`;
    });
    text += `Total Estimado del Pedido: ${subtotal.toFixed(2)} €`;

    checkoutWhatsappBtn.href = `https://wa.me/584124507289?text=${encodeURIComponent(text)}`;

    if (cartDrawer && !cartDrawer.classList.contains('translate-x-full')) {
      itemsContainer.focus();
    }
  });

  checkoutWhatsappBtn?.addEventListener('click', () => {
    setTimeout(() => {
      clearCart();
      closeCart();
    }, 1000);
  });
</script>