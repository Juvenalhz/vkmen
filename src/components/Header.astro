---
// src/components/Header.astro
import { Image } from 'astro:assets';
import logoPng from '../assets/VK_isotipo.png'; 
---

<header id="main-header" class="fixed top-0 w-full z-50 py-6 transition-all duration-300 bg-transparent">
  <div class="container mx-auto px-6 relative flex items-center justify-center">
    
    <nav class="absolute left-6 hidden lg:flex space-x-10 text-[11px] uppercase tracking-[0.3em] font-body text-white transition-colors duration-300" id="nav-left">
      <a href="/nueva-coleccion" class="hover:opacity-40 transition">New Arrivals</a>
      <a href="/polos" class="hover:opacity-40 transition">Polos</a>
    </nav>

    <div class="relative flex items-center justify-center h-12 w-64" id="logo-area">
      <div id="logo-text" class="absolute flex flex-col items-center justify-center text-white text-center transition-all duration-300">
        <span class="font-heading text-2xl tracking-[0.15em] leading-none uppercase text-nowrap">VK MEN</span>
        <span class="font-body text-[9px] tracking-[0.4em] mt-1 opacity-70 uppercase text-nowrap">Clothing Store</span>
      </div>

      <div id="logo-iso-png" class="absolute opacity-0 scale-90 transition-all duration-300">
        <Image src={logoPng} alt="VK Isotipo" class="h-10 w-auto object-contain" />
      </div>
    </div>

    <nav class="absolute right-6 hidden lg:flex space-x-10 text-[11px] uppercase tracking-[0.3em] font-body text-white transition-colors duration-300" id="nav-right">
      <a href="/pantalones" class="hover:opacity-40 transition">Pants</a>
      <a href="/accesorios" class="hover:opacity-40 transition">Accessories</a>
    </nav>

  </div>
</header>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const header = document.querySelector("#main-header") as HTMLElement;
  const logoText = document.querySelector("#logo-text") as HTMLElement;
  const logoIso = document.querySelector("#logo-iso-png") as HTMLElement;
  const navs = document.querySelectorAll("nav");

  ScrollTrigger.create({
    trigger: "body",
    start: "top top",
    end: "50", 
    onLeave: () => {
      // Al bajar: py-3 lo hace muy minimalista
      header.classList.remove('py-6', 'bg-transparent');
      header.classList.add('py-3', 'bg-white', 'shadow-md');
      
      logoText.classList.add('opacity-0', '-translate-y-2');
      logoIso.classList.remove('opacity-0', 'scale-90');
      logoIso.classList.add('opacity-100', 'scale-100');
      
      navs.forEach(nav => (nav as HTMLElement).style.color = "black");
    },
    onEnterBack: () => {
      // Al volver arriba: py-6
      header.classList.add('py-6', 'bg-transparent');
      header.classList.remove('py-3', 'bg-white', 'shadow-md');
      
      logoText.classList.remove('opacity-0', '-translate-y-2');
      logoIso.classList.add('opacity-0', 'scale-90');
      logoIso.classList.remove('opacity-100', 'scale-100');
      
      navs.forEach(nav => (nav as HTMLElement).style.color = "white");
    }
  });
</script>

<style is:global>
  #main-header {
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: 
      background-color 0.2s ease-out, 
      padding 0.2s ease-out, 
      box-shadow 0.2s ease-out;
  }
</style>