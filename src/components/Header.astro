---
// src/components/Header.astro
import { client, urlFor } from '../lib/sanity';

const headerQuery = `*[_type == "homeSettings"][0] {
  "logoScrollUrl": logoScroll.asset->url
}`;

const headerData = await client.fetch(headerQuery);

const logoDeScroll = headerData?.logoScrollUrl 
  ? urlFor(headerData.logoScrollUrl).width(150).fit('max').format('webp').url()
  : '';
---

<header id="main-header" class="fixed top-0 w-full z-50 py-3 md:py-6 transition-all duration-300 bg-transparent">
  <div class="container mx-auto px-6 relative flex items-center justify-center">
    
    <div class="relative flex items-center justify-center h-9 md:h-12 w-64" id="logo-area">
      
      <div id="logo-text" class="absolute flex flex-col items-center justify-center text-white text-center transition-all duration-300">
        <span class="font-heading text-xl md:text-2xl tracking-[0.15em] leading-none uppercase text-nowrap">VK MEN</span>
        <span class="font-body text-[8px] md:text-[9px] tracking-[0.4em] mt-0.5 opacity-70 uppercase text-nowrap">Clothing Store</span>
      </div>

      <div id="logo-iso-png" class="absolute opacity-0 scale-90 transition-all duration-300">
        {logoDeScroll && (
          <img 
            src={logoDeScroll} 
            alt="VK Isotipo" 
            class="h-8 md:h-10 w-auto object-contain"
            loading="eager"
          />
        )}
      </div>
    </div>

    </div>
</header>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const header = document.querySelector("#main-header") as HTMLElement;
  const logoText = document.querySelector("#logo-text") as HTMLElement;
  const logoIso = document.querySelector("#logo-iso-png") as HTMLElement;

  ScrollTrigger.create({
    trigger: "body",
    start: "top top",
    end: "50", 
    onLeave: () => {
      // Al bajar: se activa el fondo blanco minimalista
      header.classList.remove('md:py-6', 'bg-transparent');
      header.classList.add('py-3', 'bg-white', 'shadow-md');
      
      logoText.classList.add('opacity-0', '-translate-y-2');
      logoIso.classList.remove('opacity-0', 'scale-90');
      logoIso.classList.add('opacity-100', 'scale-100');
    },
    onEnterBack: () => {
      // Al volver arriba: regresa a transparente
      header.classList.add('md:py-6', 'bg-transparent');
      header.classList.remove('py-3', 'bg-white', 'shadow-md');
      
      logoText.classList.remove('opacity-0', '-translate-y-2');
      logoIso.classList.add('opacity-0', 'scale-90');
      logoIso.classList.remove('opacity-100', 'scale-100');
    }
  });
</script>

<style is:global>
  #main-header {
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: 
      background-color 0.2s ease-out, 
      padding 0.2s ease-out, 
      box-shadow 0.2s ease-out;
  }
</style>