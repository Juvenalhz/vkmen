---
// src/components/Hero.astro
import { client, urlFor } from '../lib/sanity';

const homeQuery = `*[_type == "homeSettings"][0] {
  heroSub,
  heroTitle,
  "heroImageUrl": heroImage.asset->url
}`;

const homeData = await client.fetch(homeQuery);

const fondoHero = homeData?.heroImageUrl 
  ? urlFor(homeData.heroImageUrl).width(1920).format('webp').url()
  : '';
---

<section id="hero" class="relative h-[50vh] md:min-h-screen w-full overflow-hidden bg-black flex items-end pb-8 md:pb-32">
  
  <div class="absolute inset-0 z-0 h-full w-full">
    {fondoHero && (
      <img 
        src={fondoHero} 
        alt="VKMEN Colección" 
        class="h-full w-full object-cover object-center"
        loading="eager"
      />
    )}
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-transparent to-black/90 z-10"></div>
  </div>

  <div class="container mx-auto px-6 relative z-20 text-white w-full">
    <div class="max-w-4xl" id="hero-content">
      
      <p class="font-body text-[9px] md:text-[11px] uppercase tracking-[0.5em] opacity-80 mb-2 md:mb-4 shadow-premium" id="hero-sub">
        {homeData?.heroSub || "Urban Luxury • Caracas"}
      </p>

      <h1 
        class="font-heading text-2xl sm:text-3xl md:text-7xl lg:text-8xl tracking-[0.05em] leading-[1.2] md:leading-[1.1] uppercase shadow-premium" 
        id="hero-title"
        set:html={homeData?.heroTitle || "The Future is<br/>Modern."}
      />

    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";

  window.addEventListener('DOMContentLoaded', () => {
    const tl = gsap.timeline({ defaults: { ease: "power3.out" }});

    gsap.from("#hero img", {
      scale: 1.05,
      duration: 2,
      ease: "power2.out"
    });

    tl.from("#hero-sub", { opacity: 0, y: 10, duration: 0.6, delay: 0.5 })
      .from("#hero-title", { opacity: 0, y: 20, duration: 0.8 }, "-=0.4");
  });
</script>

<style>
  .shadow-premium {
    text-shadow: 0px 4px 12px rgba(0, 0, 0, 0.4), 0px 2px 4px rgba(0, 0, 0, 0.2);
  }
</style>