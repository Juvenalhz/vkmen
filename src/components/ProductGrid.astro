---
// src/components/ProductGrid.astro
import { client, urlFor } from '../lib/sanity';

interface Variant {
  colorName: string;
  colorHex: string;
  availableSizes: string[];
  images: Array<{ asset: { url: string } }>;
}

interface Product {
  sku: string;
  name: string;
  category: string; 
  price: number;
  variants: Variant[];
}

// 1. Extraemos los productos Y el isotipo institucional en una sola petición
const dataQuery = `{
  "products": *[_type == "product" && count(variants[].availableSizes[]) > 0] {
    sku,
    name,
    category,
    price,
    variants[] {
      colorName,
      "colorHex": hex.hex,
      availableSizes,
      images[] { asset->{ url } }
    }
  },
  "storeSettings": *[_type == "siteSettings"][0] {
    isotipo { asset->{ url } }
  }
}`;

const { products, storeSettings } = await client.fetch(dataQuery);

// 2. Definimos el Isotipo de VKMEN como la imagen de respaldo global
// Usamos .fit('fill') y bg('FFFFFF') para centrar el logo limpiamente en el formato vertical
const vkmenIsotipo = storeSettings?.isotipo?.asset
  ? urlFor(storeSettings.isotipo).width(600).height(800).fit('fill').bg('FFFFFF').format('webp').url()
  : '/placeholder.jpg'; // Respaldo local por si acaso

// 3. Extraemos y formateamos las categorías dinámicamente de la BD con tipado explícito
const rawCategories = products.map((p: any) => p.category).filter(Boolean);
const uniqueCategories = [...new Set(rawCategories)];

const categories = [
  { title: 'Todos', value: 'all' },
  ...uniqueCategories.map((cat: any) => ({
    title: String(cat).split('-').map((word: string) => word.charAt(0).toUpperCase() + word.slice(1)).join(' '),
    value: String(cat)
  }))
];
---

<section id="catalogo" class="max-w-7xl mx-auto px-4 py-16 sm:px-6 lg:px-8 relative">
  
  <div class="flex flex-col md:flex-row md:items-baseline md:justify-between border-b border-neutral-100 pb-3 mb-12 gap-4">
    <h3 class="text-xs font-bold tracking-[0.2em] uppercase text-neutral-800 whitespace-nowrap">
      Colecciones
    </h3>
    <div class="flex overflow-x-auto md:justify-end gap-6 md:gap-10 no-scrollbar pb-1 md:pb-0 w-full md:w-auto">
      {categories.map((cat) => (
        <button
          data-category-btn={cat.value}
          class="text-xs font-medium tracking-[0.15em] uppercase pb-2 border-b border-transparent text-neutral-400 hover:text-neutral-900 transition-all duration-300 whitespace-nowrap cursor-pointer"
        >
          {cat.title}
        </button>
      ))}
    </div>
  </div>

  <div class="grid grid-cols-1 gap-y-12 gap-x-6 sm:grid-cols-2 lg:grid-cols-3 xl:gap-x-10">
    {products.map((product: Product, pIndex: number) => {
      const defaultVariant = product.variants?.[0];
      
      // BLINDAJE 1: Si no hay asset de imagen en el producto, inyectamos el Isotipo de VKMEN
      const defaultImage = (defaultVariant?.images?.[0]?.asset) 
        ? urlFor(defaultVariant.images[0]).width(600).height(800).fit('crop').format('webp').url()
        : vkmenIsotipo;

      // Estructuramos el JSON blindando el mapeo interno de imágenes para el modal dinámico
      const productDataJson = JSON.stringify({
        name: product.name,
        sku: product.sku,
        price: product.price,
        variants: (product.variants || []).map((v: Variant) => {
          const validImages = (v.images || []).filter(img => img && img.asset);
          
          return {
            colorName: v.colorName,
            colorHex: v.colorHex,
            availableSizes: v.availableSizes || [],
            thumb: validImages[0] ? urlFor(validImages[0]).width(600).height(800).fit('crop').format('webp').url() : vkmenIsotipo,
            images: validImages.length > 0 
              ? validImages.map((img: any) => urlFor(img).width(800).height(1000).fit('crop').format('webp').url())
              : [vkmenIsotipo]
          };
        })
      });

      return (
        <div data-product-card={product.category} class="group bg-white flex flex-col justify-between">
          <div data-open-modal data-product-info={productDataJson} class="relative w-full h-112.5 bg-neutral-50 overflow-hidden cursor-pointer">
            <img 
              id={`prod-img-${pIndex}`}
              src={defaultImage} 
              alt={product.name}
              class="w-full h-full object-center object-cover transition-all duration-500 group-hover:scale-102"
              loading="lazy"
              style="transition: opacity 0.15s ease-in-out;"
            />
            <div class="absolute inset-0 bg-black/5 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
              <span class="bg-white/90 text-neutral-900 text-[10px] tracking-widest uppercase px-4 py-2 font-medium shadow-sm">Ver Detalle</span>
            </div>
          </div>

          <div class="mt-4 flex justify-between items-start">
            <div class="space-y-1">
              <span class="block text-[9px] font-mono tracking-widest text-neutral-400 uppercase">{product.sku}</span>
              <h2 class="text-xs font-medium tracking-wider text-neutral-800 uppercase">{product.name}</h2>
            </div>
            <p class="text-xs font-bold tracking-wider text-neutral-900">{product.price} €</p>
          </div>

          <div class="mt-4 pt-3 border-t border-neutral-100 flex justify-between items-center">
            <div class="flex gap-2.5">
              {(product.variants || []).map((v: Variant, vIndex: number) => {
                const imgUrl = (v.images?.[0]?.asset) 
                  ? urlFor(v.images[0]).width(600).height(800).fit('crop').format('webp').url()
                  : vkmenIsotipo;
                
                const sizesString = (v && v.availableSizes && Array.isArray(v.availableSizes)) 
                  ? v.availableSizes.join(' · ') 
                  : 'Sin Tallas';

                return (
                  <button 
                    data-color-select
                    data-target-img={`prod-img-${pIndex}`}
                    data-target-sizes={`prod-sizes-${pIndex}`}
                    data-img-src={imgUrl}
                    data-sizes={sizesString}
                    class={`w-5 h-5 rounded-full border border-neutral-300 block shadow-sm cursor-pointer transition-transform hover:scale-110 focus:outline-none ${vIndex === 0 ? 'ring-1 ring-neutral-900 ring-offset-2' : ''}`}
                    style={`background-color: ${v.colorHex}`}
                    title={v.colorName}
                  />
                );
              })}
            </div>
            
            <span id={`prod-sizes-${pIndex}`} class="text-[9px] font-bold tracking-widest text-neutral-500 font-mono">
              {(defaultVariant && defaultVariant.availableSizes && Array.isArray(defaultVariant.availableSizes)) 
                ? defaultVariant.availableSizes.join(' · ') 
                : 'Agotado'}
            </span>
          </div>
        </div>
      );
    })}
  </div>

  <div id="product-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/60 backdrop-blur-sm">
    <div class="bg-white w-full max-w-4xl max-h-[95vh] md:max-h-[90vh] overflow-y-auto rounded-none flex flex-col md:flex-row relative shadow-2xl">
      
      <button id="close-modal" class="absolute top-4 right-4 z-10 p-2 text-neutral-400 hover:text-neutral-900 cursor-pointer bg-white/80 md:bg-transparent rounded-full shadow-sm md:shadow-none">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>

      <div id="modal-img-container" class="w-full md:w-1/2 bg-neutral-50 flex flex-col justify-between border-b md:border-b-0 md:border-r border-neutral-100 transition-all duration-300">
        <div class="w-full h-95 md:h-120 overflow-hidden relative group/zoom">
          <img id="modal-img" src="" alt="" class="w-full h-full object-cover object-center transition-all duration-300 cursor-zoom-in" style="transition: opacity 0.15s ease-in-out;">
          <div class="absolute bottom-3 right-3 bg-black/40 text-white pointer-events-none p-1.5 rounded-full backdrop-blur-sm opacity-0 group-hover/zoom:opacity-100 transition-opacity">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.637 10.637zM10.5 7.5v6m3-3h-6" />
            </svg>
          </div>
        </div>
        <div id="modal-thumbnails-container" class="hidden gap-2 px-4 mt-3 overflow-x-auto no-scrollbar justify-start"></div>
      </div>

      <div class="w-full md:w-1/2 p-6 md:p-10 flex flex-col justify-between bg-white">
        <div class="space-y-6">
          <div>
            <span id="modal-sku" class="text-[10px] font-mono tracking-widest text-neutral-400 uppercase"></span>
            <h2 id="modal-title" class="text-xl font-light tracking-wide text-neutral-900 uppercase font-serif mt-1"></h2>
            <p id="modal-price" class="text-lg font-bold text-neutral-900 mt-2"></p>
          </div>

          <div>
            <p class="text-[10px] font-medium tracking-widest text-neutral-400 uppercase mb-3">Color disponible</p>
            <div id="modal-colors-container" class="flex gap-3"></div>
          </div>

          <div>
            <p class="text-[10px] font-medium tracking-widest text-neutral-400 uppercase mb-3">Selecciona tu talla</p>
            <div id="modal-sizes-container" class="flex flex-wrap gap-2"></div>
          </div>
        </div>

        <div class="mt-8">
          <button 
            id="modal-add-to-cart-btn"
            class="w-full block text-center bg-neutral-900 text-white text-xs font-semibold tracking-[0.2em] uppercase py-4 hover:bg-neutral-800 transition-all cursor-pointer disabled:opacity-50"
          >
            Añadir al Carrito
          </button>
        </div>
      </div>

    </div>
  </div>

  <div id="image-lightbox" class="fixed inset-0 z-60 hidden items-center justify-center bg-black/95 backdrop-blur-md cursor-zoom-out select-none">
    <button id="close-lightbox" class="absolute top-6 right-6 p-3 text-white/70 hover:text-white transition-colors cursor-pointer">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
    <div class="max-w-[95vw] max-h-[90vh] flex items-center justify-center">
      <img id="lightbox-img" src="" alt="VKMEN Detalle Expandido" class="max-w-full max-h-[85vh] object-contain shadow-2xl transition-transform duration-300 ease-out">
    </div>
  </div>

  <div 
    id="floating-cart-btn" 
    class="fixed bottom-6 right-6 z-40 bg-neutral-900 text-white p-4 rounded-full shadow-xl transition-all duration-300 transform translate-y-20 opacity-0 scale-90 hover:bg-neutral-800 hover:scale-105 active:scale-95 cursor-pointer flex items-center justify-center"
    title="Ver mi bolsa de compras"
  >
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375 .375 0 1 1-.75 0 .375 .375 0 0 1 .75 0Zm7.5 0a.375 .375 0 1 1-.75 0 .375 .375 0 0 1 .75 0Z" />
    </svg>
    <span 
      id="floating-cart-count" 
      class="absolute -top-1 -right-1 bg-amber-600 text-white font-mono text-[10px] font-bold w-5 h-5 rounded-full flex items-center justify-center border border-neutral-900"
    >
      0
    </span>
  </div>
</section>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  import { cartItems, addCartItem } from '../store/cartStore.js';

  // Usamos as HTMLElement para mitigar el error de tipo 'never' o elementos nulos en TypeScript
  const floatingCartBtn = document.getElementById('floating-cart-btn') as HTMLElement | null;
  const floatingCartCount = document.getElementById('floating-cart-count') as HTMLElement | null;
  const cartDrawer = document.getElementById('cart-drawer') as HTMLElement | null;
  const cartOverlay = document.getElementById('cart-overlay') as HTMLElement | null;

  // --- 1. ESCUCHADOR REACTIVO DEL CARRITO ---
  cartItems.subscribe((items: any[]) => {
    if (!floatingCartBtn || !floatingCartCount) return;
    
    const totalQuantity = items.reduce((acc: number, item: any) => acc + item.quantity, 0);
    floatingCartCount.textContent = totalQuantity.toString();

    if (totalQuantity > 0) {
      floatingCartBtn.classList.remove('translate-y-20', 'opacity-0', 'scale-90');
      floatingCartBtn.classList.add('translate-y-0', 'opacity-100', 'scale-100');
    } else {
      floatingCartBtn.classList.remove('translate-y-0', 'opacity-100', 'scale-100');
      floatingCartBtn.classList.add('translate-y-20', 'opacity-0', 'scale-90');
    }
  });

  floatingCartBtn?.addEventListener('click', () => {
    if (cartDrawer && cartOverlay) {
      cartDrawer.classList.remove('translate-x-full');
      cartOverlay.classList.remove('hidden');
      setTimeout(() => cartOverlay.classList.remove('opacity-0'), 10);
      document.body.style.overflow = 'hidden';
    }
  });

  // --- 2. FILTRADO DE CATEGORÍAS ---
  const catButtons = document.querySelectorAll('[data-category-btn]');
  const productCards = document.querySelectorAll('[data-product-card]');
  const allBtn = document.querySelector('[data-category-btn="all"]');
  if (allBtn) {
    allBtn.classList.remove('text-neutral-400');
    allBtn.classList.add('text-neutral-900', 'border-neutral-900');
  }
  catButtons.forEach(button => {
    button.addEventListener('click', () => {
      const selectedCategory = button.getAttribute('data-category-btn');
      catButtons.forEach(btn => {
        btn.classList.remove('text-neutral-900', 'border-neutral-900');
        btn.classList.add('text-neutral-400', 'border-transparent');
      });
      button.classList.remove('text-neutral-400', 'border-transparent');
      button.classList.add('text-neutral-900', 'border-neutral-900');

      productCards.forEach(card => {
        const productCategory = card.getAttribute('data-product-card');
        if (selectedCategory === 'all' || productCategory === selectedCategory) {
          (card as HTMLElement).style.display = 'flex';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });

  // --- 3. CAMBIO DE COLOR EN LA GRILLA ---
  const colorButtons = document.querySelectorAll('[data-color-select]');
  colorButtons.forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.stopPropagation();
      const targetImgId = btn.getAttribute('data-target-img');
      const targetSizesId = btn.getAttribute('data-target-sizes');
      const newImgSrc = btn.getAttribute('data-img-src');
      const newSizes = btn.getAttribute('data-sizes');

      if (targetImgId && newImgSrc) {
        const imgElement = document.getElementById(targetImgId) as HTMLImageElement;
        if (imgElement && imgElement.src !== newImgSrc) {
          imgElement.style.opacity = '0.3';
          
          const tempImg = new Image();
          tempImg.src = newImgSrc;
          try { await tempImg.decode(); } catch(e) {}
          
          imgElement.src = newImgSrc;
          imgElement.style.opacity = '1';
        }
      }
      if (targetSizesId && newSizes) {
        const sizesElement = document.getElementById(targetSizesId);
        if (sizesElement) sizesElement.textContent = newSizes;
      }
      const parentContainer = btn.parentElement;
      if (parentContainer) {
        const siblingButtons = parentContainer.querySelectorAll('[data-color-select]');
        siblingButtons.forEach(sBtn => sBtn.classList.remove('ring-1', 'ring-neutral-900', 'ring-offset-2'));
      }
      btn.classList.add('ring-1', 'ring-neutral-900', 'ring-offset-2');
    });
  });

  // --- 4. PRECARGA AGRESIVA ---
  const executeUltraPreload = () => {
    colorButtons.forEach(btn => {
      const imgSrc = btn.getAttribute('data-img-src');
      if (imgSrc && !imgSrc.includes('placeholder')) {
        const img = new Image();
        img.src = imgSrc;
      }
    });

    const openModalElements = document.querySelectorAll('[data-open-modal]');
    openModalElements.forEach(element => {
      const rawData = element.getAttribute('data-product-info');
      if (!rawData) return;
      try {
        const product = JSON.parse(rawData);
        product.variants?.forEach((v: any) => {
          if (v.thumb && !v.thumb.includes('placeholder')) { const i = new Image(); i.src = v.thumb; }
          v.images?.forEach((imgUrl: string) => {
            if (imgUrl && !imgUrl.includes('placeholder')) { const i = new Image(); i.src = imgUrl; }
          });
        });
      } catch (err) {}
    });
  };

  const globalScope = typeof window !== 'undefined' ? (window as any) : null;
  if (globalScope) {
    if (typeof globalScope.requestIdleCallback === 'function') {
      globalScope.requestIdleCallback(executeUltraPreload);
    } else {
      globalScope.addEventListener('load', executeUltraPreload);
    }
  }

  // --- 5. LÓGICA DEL MODAL ---
  const openModalElements = document.querySelectorAll('[data-open-modal]');
  const modal = document.getElementById('product-modal') as HTMLElement | null;
  const closeModalBtn = document.getElementById('close-modal') as HTMLElement | null;
  
  const modalImgContainer = document.getElementById('modal-img-container') as HTMLElement | null;
  const modalImg = document.getElementById('modal-img') as HTMLImageElement | null;
  const modalSku = document.getElementById('modal-sku') as HTMLElement | null;
  const modalTitle = document.getElementById('modal-title') as HTMLElement | null;
  const modalPrice = document.getElementById('modal-price') as HTMLElement | null;
  const modalColorsContainer = document.getElementById('modal-colors-container') as HTMLElement | null;
  const modalSizesContainer = document.getElementById('modal-sizes-container') as HTMLElement | null;
  const modalThumbnailsContainer = document.getElementById('modal-thumbnails-container') as HTMLElement | null;
  const addToCartBtn = document.getElementById('modal-add-to-cart-btn') as HTMLButtonElement | null;

  const lightbox = document.getElementById('image-lightbox') as HTMLElement | null;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;

  let activeProduct: any = null;
  let activeVariant: any = null;
  let activeSize: string = '';

  openModalElements.forEach(element => {
    element.addEventListener('click', () => {
      const rawData = element.getAttribute('data-product-info');
      if (!rawData || !modal) return;
      
      if (modalImg) modalImg.src = ''; 

      activeProduct = JSON.parse(rawData);
      activeVariant = activeProduct.variants[0];
      
      const initialSizes = activeVariant?.availableSizes || [];
      activeSize = initialSizes[0] || '';

      const updateModalContent = async (variant: any) => {
        activeVariant = variant;
        
        if (modalImg) {
          if (variant?.thumb) modalImg.src = variant.thumb;
          
          if (variant?.images?.[0]) {
            const highResImage = new Image();
            highResImage.src = variant.images[0];
            try {
              await highResImage.decode();
              if (activeVariant === variant) {
                modalImg.src = variant.images[0];
              }
            } catch (e) {
              if (activeVariant === variant) modalImg.src = variant.images[0];
            }
          }
        }
        
        if (modalThumbnailsContainer && modalImgContainer) {
          modalThumbnailsContainer.innerHTML = '';
          if (variant?.images && variant.images.length > 1) {
            modalThumbnailsContainer.classList.remove('hidden');
            modalThumbnailsContainer.classList.add('flex');
            modalImgContainer.classList.add('pb-4');

            variant.images.forEach((imgUrl: string, idx: number) => {
              const thumbBtn = document.createElement('button');
              thumbBtn.className = `w-14 h-18 bg-neutral-100 border overflow-hidden cursor-pointer flex-shrink-0 transition-all ${idx === 0 ? 'border-neutral-900 opacity-100' : 'border-neutral-200 opacity-60 hover:opacity-100'}`;
              
              const thumbImg = document.createElement('img');
              thumbImg.src = imgUrl;
              thumbImg.className = 'w-full h-full object-cover object-center';
              thumbBtn.appendChild(thumbImg);
              
              thumbBtn.addEventListener('click', async () => {
                if (modalImg) {
                  modalImg.style.opacity = '0.4';
                  const tImg = new Image();
                  tImg.src = imgUrl;
                  try { await tImg.decode(); } catch(e) {}
                  modalImg.src = imgUrl;
                  modalImg.style.opacity = '1';
                }
                const allThumbs = modalThumbnailsContainer.querySelectorAll('button');
                allThumbs.forEach(b => {
                  b.classList.remove('border-neutral-900', 'opacity-100');
                  b.classList.add('border-neutral-200', 'opacity-60');
                });
                thumbBtn.classList.remove('border-neutral-200', 'opacity-60');
                thumbBtn.classList.add('border-neutral-900', 'opacity-100');
              });

              modalThumbnailsContainer.appendChild(thumbBtn);
            });
          } else {
            modalThumbnailsContainer.classList.remove('flex');
            modalThumbnailsContainer.classList.add('hidden');
            modalImgContainer.classList.remove('pb-4');
          }
        }

        if (modalSizesContainer) {
          modalSizesContainer.innerHTML = '';
          const sizesList = variant?.availableSizes || [];
          if (!sizesList.includes(activeSize)) {
            activeSize = sizesList[0] || '';
          }

          sizesList.forEach((size: string) => {
            const sizeBtn = document.createElement('button');
            sizeBtn.className = `border px-4 py-2 text-xs font-mono font-bold transition-all cursor-pointer focus:outline-none ${
              size === activeSize 
                ? 'border-neutral-900 bg-neutral-900 text-white shadow-sm' 
                : 'border-neutral-200 bg-neutral-50 text-neutral-700 hover:border-neutral-400'
            }`;
            sizeBtn.textContent = size;
            
            sizeBtn.addEventListener('click', () => {
              activeSize = size;
              const allSizeBtns = modalSizesContainer.querySelectorAll('button');
              allSizeBtns.forEach(b => {
                b.classList.remove('border-neutral-900', 'bg-neutral-900', 'text-white');
                b.classList.add('border-neutral-200', 'bg-neutral-50', 'text-neutral-700');
              });
              sizeBtn.classList.remove('border-neutral-200', 'bg-neutral-50', 'text-neutral-700');
              sizeBtn.classList.add('border-neutral-900', 'bg-neutral-900', 'text-white');
            });

            modalSizesContainer.appendChild(sizeBtn);
          });
        }
      };

      if (modalSku) modalSku.textContent = `SKU: ${activeProduct.sku}`;
      if (modalTitle) modalTitle.textContent = activeProduct.name;
      if (modalPrice) modalPrice.textContent = `${activeProduct.price} €`;
      
      if (modalColorsContainer) {
        modalColorsContainer.innerHTML = '';
        activeProduct.variants?.forEach((v: any, index: number) => {
          const btn = document.createElement('button');
          btn.className = `w-6 h-6 rounded-full border border-neutral-300 block cursor-pointer transition-all ${index === 0 ? 'ring-1 ring-neutral-900 ring-offset-2' : ''}`;
          btn.style.backgroundColor = v.colorHex;
          btn.title = v.colorName;
          
          btn.addEventListener('click', () => {
            const allModalColorBtns = modalColorsContainer.querySelectorAll('button');
            allModalColorBtns.forEach(b => b.classList.remove('ring-1', 'ring-neutral-900', 'ring-offset-2'));
            btn.classList.add('ring-1', 'ring-neutral-900', 'ring-offset-2');
            updateModalContent(v);
          });

          modalColorsContainer.appendChild(btn);
        });
      }

      updateModalContent(activeVariant);
      modal.style.display = 'flex';
    });
  });

  addToCartBtn?.addEventListener('click', () => {
    if (!activeProduct || !activeVariant) return;

    addCartItem({
      sku: activeProduct.sku,
      name: activeProduct.name,
      price: activeProduct.price,
      colorName: activeVariant.colorName,
      colorHex: activeVariant.colorHex,
      size: activeSize,
      image: activeVariant.images?.[0] || ''
    });

    const originalText = addToCartBtn.textContent;
    addToCartBtn.textContent = "¡Añadido Exitosamente!";
    addToCartBtn.classList.remove('bg-neutral-900');
    addToCartBtn.classList.add('bg-amber-600');
    addToCartBtn.disabled = true;

    setTimeout(() => {
      addToCartBtn.textContent = originalText;
      addToCartBtn.classList.remove('bg-amber-600');
      addToCartBtn.classList.add('bg-neutral-900');
      addToCartBtn.disabled = false;
      if (modal) modal.style.display = 'none';
      document.body.style.overflow = '';
    }, 800);
  });

  // --- 6. LIGHTBOX ---
  if (modalImg && lightbox && lightboxImg) {
    modalImg.addEventListener('click', () => {
      if (modalImg.src) {
        lightboxImg.src = modalImg.src;
        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
        document.body.style.overflow = 'hidden';
      }
    });
  }

  if (lightbox) {
    lightbox.addEventListener('click', () => {
      lightbox.classList.remove('flex');
      lightbox.classList.add('hidden');
      if (modal && modal.style.display === 'none') {
        document.body.style.overflow = '';
      }
    });
  }

  if (closeModalBtn && modal) {
    closeModalBtn.addEventListener('click', () => {
      modal.style.display = 'none';
      document.body.style.overflow = '';
    });
    modal.addEventListener('click', (e) => {
      if (e.target === modal) {
        modal.style.display = 'none';
        document.body.style.overflow = '';
      }
    });
  }
</script>